# secrets — API keys for judge regeneration (not needed to reproduce metrics)
.env

# node
node_modules/

# trained model binaries (~1.5 GB) — regenerate from notebooks/, see README
models/

# os
.DS_Store

# transient full-context re-grade run logs
data/eval/fullctx*.log
data/eval/judge_fail.log
data/eval/scores_fullctx.json
data/eval/scores_fullctx_class.json

# regenerable per-item detail dumps (see REVIEW_MANIFEST)
data/eval/detail_dump_*.json

# regenerable viewer intermediate (viewer.html embeds this; rebuild via server/eval/build_viewer.mjs)
data/eval/viewer_data.json

# unpacked arXiv staging dir (regenerable; the committed tarball is the artifact)
paper/arxiv/arxiv_upload/

# python bytecode
__pycache__/
*.pyc
